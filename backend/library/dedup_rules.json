{
  "version": 2,
  "schema": {
    "match_column": "{column, method, threshold?, aliases?}",
    "action_class": "auto_merge | review_required | flag_only",
    "notes": "Free-text business context shown in the dialog tooltip.",
    "min_group_size": "Skip groups smaller than this — defaults to 2."
  },
  "rules": [
    {
      "id": "vendor-domestic-name-pan-gst",
      "stream": "vendor",
      "label": "Vendor — Domestic (Name + PAN + GST exact)",
      "description": "Two vendors with the same name, PAN, and GST number are the same Indian legal entity. All three must match exactly.",
      "kind": "duplicate",
      "match_strategy": "exact",
      "match_columns": [
        {
          "column": "name",
          "method": "exact",
          "aliases": ["vendor_name", "legal_name", "company_name", "supplier_name", "trade_name"]
        },
        {
          "column": "pan_number",
          "method": "exact",
          "aliases": ["pan", "pan_no", "permanent_account_number"]
        },
        {
          "column": "gst_number",
          "method": "exact",
          "aliases": ["gstin", "gst", "gst_no", "gst_in"]
        }
      ],
      "survivorship": {
        "strategy": "field_level_merge",
        "priority": ["most_complete", "most_recent"],
        "recency_column": "updated_at"
      },
      "severity": "high",
      "action_class": "auto_merge",
      "notes": "Indian vendors with identical name + PAN + GST are guaranteed duplicates. Safe to auto-merge — PAN identifies the parent entity and GST identifies the state registration; together with name they're an unambiguous match.",
      "min_group_size": 2,
      "source": "library",
      "version": 3
    },
    {
      "id": "vendor-international-name-address",
      "stream": "vendor",
      "label": "Vendor — International (Name + Address)",
      "description": "Two international vendors with similar names and similar addresses. Used when PAN / GST don't apply.",
      "kind": "duplicate",
      "match_strategy": "fuzzy",
      "match_columns": [
        {
          "column": "name",
          "method": "token_sort_ratio",
          "threshold": 0.85,
          "aliases": ["vendor_name", "legal_name", "company_name", "supplier_name", "trade_name"]
        },
        {
          "column": "address",
          "method": "token_sort_ratio",
          "threshold": 0.80,
          "aliases": ["address_line", "full_address", "billing_address", "street", "registered_address", "street_address"]
        }
      ],
      "survivorship": {
        "strategy": "field_level_merge",
        "priority": ["most_complete", "most_recent"],
        "recency_column": "updated_at"
      },
      "severity": "high",
      "action_class": "review_required",
      "notes": "International vendors lack Indian tax IDs, so duplicate detection falls back to name + address fuzzy matching. Address threshold is slightly lower (80%) because addresses vary in formatting (\"St.\" vs \"Street\", line breaks, postal-code position).",
      "min_group_size": 2,
      "source": "library",
      "version": 3
    },

    {
      "id": "customer-domestic-name-pan-gst",
      "stream": "customer",
      "label": "Customer — Domestic (Name + PAN + GST exact)",
      "description": "Two customers with the same name, PAN, and GST number are the same Indian legal entity. All three must match exactly.",
      "kind": "duplicate",
      "match_strategy": "exact",
      "match_columns": [
        {
          "column": "name",
          "method": "exact",
          "aliases": ["customer_name", "legal_name", "company_name", "client_name"]
        },
        {
          "column": "pan_number",
          "method": "exact",
          "aliases": ["pan", "pan_no", "permanent_account_number"]
        },
        {
          "column": "gst_number",
          "method": "exact",
          "aliases": ["gstin", "gst", "gst_no", "gst_in"]
        }
      ],
      "survivorship": {
        "strategy": "field_level_merge",
        "priority": ["most_complete", "most_recent"],
        "recency_column": "updated_at"
      },
      "severity": "high",
      "action_class": "auto_merge",
      "notes": "Indian customers with identical name + PAN + GST are guaranteed duplicates. Safe to auto-merge — PAN identifies the parent entity, GST identifies the state registration; together with name they're an unambiguous match.",
      "min_group_size": 2,
      "source": "library",
      "version": 3
    },
    {
      "id": "customer-international-name-address",
      "stream": "customer",
      "label": "Customer — International (Name + Address)",
      "description": "Two international customers with similar names and similar addresses. Used when PAN / GST don't apply.",
      "kind": "duplicate",
      "match_strategy": "fuzzy",
      "match_columns": [
        {
          "column": "name",
          "method": "token_sort_ratio",
          "threshold": 0.85,
          "aliases": ["customer_name", "legal_name", "company_name", "client_name"]
        },
        {
          "column": "address",
          "method": "token_sort_ratio",
          "threshold": 0.80,
          "aliases": ["address_line", "full_address", "billing_address", "street", "registered_address", "street_address"]
        }
      ],
      "survivorship": {
        "strategy": "field_level_merge",
        "priority": ["most_complete", "most_recent"],
        "recency_column": "updated_at"
      },
      "severity": "high",
      "action_class": "review_required",
      "notes": "International customers lack Indian tax IDs, so duplicate detection falls back to name + address fuzzy matching. Address threshold is slightly lower (80%) because addresses vary in formatting (\"St.\" vs \"Street\", line breaks, postal-code position).",
      "min_group_size": 2,
      "source": "library",
      "version": 3
    },

    {
      "id": "material-exact-sku",
      "stream": "material",
      "label": "Material — exact SKU",
      "description": "Two material rows with the same SKU are duplicates.",
      "kind": "duplicate",
      "match_strategy": "exact",
      "match_columns": [
        {
          "column": "sku",
          "method": "exact_non_null",
          "aliases": ["matnr", "material_number", "item_code", "product_code", "part_number"]
        }
      ],
      "survivorship": {
        "strategy": "most_recent",
        "recency_column": "updated_at"
      },
      "severity": "high",
      "action_class": "auto_merge",
      "notes": "SKUs are by design unique within a catalog. Same SKU ⇒ same item.",
      "min_group_size": 2,
      "source": "library",
      "version": 2
    },
    {
      "id": "material-exact-barcode",
      "stream": "material",
      "label": "Material — exact EAN / UPC barcode",
      "description": "Two materials with the same global trade item number.",
      "kind": "duplicate",
      "match_strategy": "exact",
      "match_columns": [
        {
          "column": "barcode",
          "method": "exact_non_null",
          "aliases": ["ean", "ean13", "ean_upc", "gtin", "upc", "isbn"]
        }
      ],
      "survivorship": {
        "strategy": "field_level_merge",
        "priority": ["most_complete", "most_recent"]
      },
      "severity": "high",
      "action_class": "auto_merge",
      "notes": "GTIN / EAN is globally unique per product. Reliable auto-merge.",
      "min_group_size": 2,
      "source": "library",
      "version": 2
    },
    {
      "id": "material-fuzzy-description-category",
      "stream": "material",
      "label": "Material — fuzzy description + same category",
      "description": "Catches typo or casing variations of the same item within a category.",
      "kind": "duplicate",
      "match_strategy": "fuzzy",
      "match_columns": [
        {
          "column": "description",
          "method": "token_sort_ratio",
          "threshold": 0.80,
          "aliases": ["maktx", "material_description", "item_description", "long_text", "product_description"]
        },
        {
          "column": "category",
          "method": "exact",
          "aliases": ["matkl", "material_group", "product_group", "item_category"]
        }
      ],
      "survivorship": {
        "strategy": "field_level_merge",
        "priority": ["most_complete"]
      },
      "severity": "medium",
      "action_class": "review_required",
      "notes": "Lower threshold (80%) because material descriptions vary in spec ordering (\"M8 x 50mm bolt\" vs \"Bolt M8 50mm\").",
      "min_group_size": 2,
      "source": "library",
      "version": 2
    },

    {
      "id": "employee-exact-national-id",
      "stream": "employee",
      "label": "Employee — exact national ID",
      "description": "Two employees with the same PAN / SSN / national identifier.",
      "kind": "duplicate",
      "match_strategy": "exact",
      "match_columns": [
        {
          "column": "national_id",
          "method": "exact_non_null",
          "aliases": ["pan_number", "ssn", "aadhaar", "nin", "national_insurance_number"]
        }
      ],
      "survivorship": {
        "strategy": "most_recent",
        "recency_column": "hire_date"
      },
      "severity": "high",
      "action_class": "review_required",
      "notes": "Re-hires legitimately share national ID across records. Don't auto-merge — keep the hire history and treat as one person.",
      "min_group_size": 2,
      "source": "library",
      "version": 2
    },
    {
      "id": "employee-fuzzy-name-dob",
      "stream": "employee",
      "label": "Employee — fuzzy name + same date of birth",
      "description": "Useful when national ID is masked or missing. Two employees with similar names and identical DOB.",
      "kind": "duplicate",
      "match_strategy": "fuzzy",
      "match_columns": [
        {
          "column": "name",
          "method": "token_sort_ratio",
          "threshold": 0.90,
          "aliases": ["full_name", "employee_name", "person_name"]
        },
        {
          "column": "date_of_birth",
          "method": "exact",
          "aliases": ["dob", "birth_date", "birthdate"]
        }
      ],
      "survivorship": {
        "strategy": "most_recent",
        "recency_column": "hire_date"
      },
      "severity": "medium",
      "action_class": "review_required",
      "notes": "Tight name threshold (90%) because two unrelated employees sharing a DOB is common in large organisations.",
      "min_group_size": 2,
      "source": "library",
      "version": 2
    },

    {
      "id": "gl-exact-account-number",
      "stream": "gl_account",
      "label": "GL — exact account number",
      "description": "Two GL master rows with the same account number within the same chart of accounts.",
      "kind": "duplicate",
      "match_strategy": "exact",
      "match_columns": [
        {
          "column": "account_number",
          "method": "exact_non_null",
          "aliases": ["saknr", "gl_account", "account_code", "account_id"]
        },
        {
          "column": "chart_of_accounts",
          "method": "exact",
          "aliases": ["ktopl", "coa", "chart_id"]
        }
      ],
      "survivorship": {
        "strategy": "most_recent",
        "recency_column": "updated_at"
      },
      "severity": "high",
      "action_class": "auto_merge",
      "notes": "Within a single chart of accounts, the account number is unique by design. Safe auto-merge.",
      "min_group_size": 2,
      "source": "library",
      "version": 2
    },
    {
      "id": "gl-fuzzy-description-coa",
      "stream": "gl_account",
      "label": "GL — fuzzy description + same chart of accounts",
      "description": "Same kind of account under different numbers within one chart of accounts — typically migration noise.",
      "kind": "duplicate",
      "match_strategy": "fuzzy",
      "match_columns": [
        {
          "column": "description",
          "method": "token_sort_ratio",
          "threshold": 0.85,
          "aliases": ["txt50", "txt20", "long_description", "account_description"]
        },
        {
          "column": "chart_of_accounts",
          "method": "exact",
          "aliases": ["ktopl", "coa"]
        }
      ],
      "survivorship": {
        "strategy": "field_level_merge",
        "priority": ["most_complete"]
      },
      "severity": "medium",
      "action_class": "review_required",
      "notes": "Catches \"Office Supplies\" vs \"OFFICE SUPPLIES\" vs \"Office supply\". Often the survivor needs to be the one with the lower account number (more senior).",
      "min_group_size": 2,
      "source": "library",
      "version": 2
    },

    {
      "id": "cost-center-exact-code",
      "stream": "cost_center",
      "label": "Cost centre — exact code",
      "description": "Two cost centres sharing the same code within the same controlling area.",
      "kind": "duplicate",
      "match_strategy": "exact",
      "match_columns": [
        {
          "column": "cost_center_code",
          "method": "exact_non_null",
          "aliases": ["kostl", "kostl_code", "cc_code", "cost_centre_code"]
        }
      ],
      "survivorship": {
        "strategy": "most_recent",
        "recency_column": "valid_from"
      },
      "severity": "high",
      "action_class": "auto_merge",
      "notes": "Cost centre codes are unique within a controlling area. Same code ⇒ same cost centre.",
      "min_group_size": 2,
      "source": "library",
      "version": 2
    }
  ]
}
